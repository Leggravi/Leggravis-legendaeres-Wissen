<?xml version="1.0" ?>
<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8">
  <properties>
    <titles>
      <title>Uns're Leuchte ist das Lamm</title>
    </titles>
    <authors>
      <author>Unbekannt</author>
    </authors>
    <verseOrder>v1</verseOrder>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Uns're Leuchte ist das Lamm,
dass Lamm auf dem Thron.
Halleluja, halleluja,
dem Lamm auf dem Thron.</lines>
    </verse>
  </lyrics>
</song>
