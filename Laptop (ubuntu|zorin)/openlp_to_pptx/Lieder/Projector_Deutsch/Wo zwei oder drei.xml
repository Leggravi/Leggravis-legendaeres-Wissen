<?xml version="1.0" ?>
<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8">
  <properties>
    <titles>
      <title>Wo zwei oder drei</title>
    </titles>
    <authors>
      <author type="words">Aus der Bibel</author>
      <author type="music">Markus Hinz</author>
    </authors>
    <verseOrder>v1</verseOrder>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Wo zwei oder drei in meinem Namen versammelt sind,
da bin ich mitten unter ihnen.</lines>
    </verse>
  </lyrics>
</song>
