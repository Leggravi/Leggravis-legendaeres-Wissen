<?xml version="1.0" ?>
<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8">
  <properties>
    <titles>
      <title>Ich sing Lobpreis Deinen Nam</title>
    </titles>
    <authors>
      <author>Unbekannt</author>
    </authors>
    <verseOrder>v1</verseOrder>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Ich sing Lobpreis Deinen Nam' o Herr.
Lobpreis Deinen Nam' o Herr.
Denn Dein Nam' ist groß,
und würdig unser Lob.</lines>
    </verse>
  </lyrics>
</song>
