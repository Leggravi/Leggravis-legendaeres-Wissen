<?xml version="1.0" ?>
<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8">
  <properties>
    <titles>
      <title>Aber das ist meine Freude</title>
    </titles>
    <authors>
      <author type="words">Benjamin Schmolck</author>
      <author type="music">Jesu, deine tiefen Wunden</author>
    </authors>
    <verseOrder>v1</verseOrder>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Aber das ist meine Freude,
dass ich mich zu Gott halte
und meine Zuversicht setze
auf Gott dem Herrn,
verkündige all sein Tun.</lines>
    </verse>
  </lyrics>
</song>
