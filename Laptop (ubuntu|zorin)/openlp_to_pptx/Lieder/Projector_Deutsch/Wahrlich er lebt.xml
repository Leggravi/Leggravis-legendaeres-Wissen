  <properties>
    <titles>
      <title>Wahrlich, er lebt!</title>
    </titles>
    <authors>
      <author type="words">Unbekannt</author>
      <author type="music">John Watson</author>
    </authors>
    <verseOrder>v1</verseOrder>
