    <verse name="v1">
      <lines>|:|ch verherrliche meinen großen Gott; ich singe ihm ein neues Lied :|
|: Preis und Ehre, ich singe ihm ein neues Lied :|
|: Halleluja, halleluja, halleluja, :|</lines>
    </verse>
  </lyrics>
