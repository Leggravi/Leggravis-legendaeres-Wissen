<?xml version="1.0" ?>
<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8">
  <properties>
    <titles>
      <title>Was wollen wir sagen</title>
    </titles>
    <authors>
      <author type="words">Max Runge</author>
      <author type="music">Paul Sonderhaus</author>
    </authors>
    <verseOrder>v1 v2</verseOrder>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Was wollen wir sagen dem Herrn,
Wir wollen sagen: Danke Herr.</lines>
    </verse>
    <verse name="v2">
      <lines>Danke Herr,
Danke Herr, wir wollen sagen
Danke Herr</lines>
    </verse>
  </lyrics>
</song>
