<?xml version="1.0" ?>
<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8">
  <properties>
    <titles>
      <title>Ich will feiern und singen</title>
    </titles>
    <authors>
      <author>Unbekannt</author>
    </authors>
    <verseOrder>v1 v2 v3</verseOrder>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Ich will feiern und singen unser'm Herrn,
Ich singe ihm ein neues Lied.</lines>
    </verse>
    <verse name="v2">
      <lines>Ich will preisen
Ich singe ihm ein neues Lied.</lines>
    </verse>
    <verse name="v3">
      <lines>Halleluja, Halleluja, Halleluja</lines>
    </verse>
  </lyrics>
</song>
