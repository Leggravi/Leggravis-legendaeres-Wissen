<?xml version="1.0" ?>
<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8">
  <properties>
    <titles>
      <title>Cast Your Burdens</title>
    </titles>
    <authors>
      <author type="words">Unbekannt</author>
      <author type="music">Unbekannt</author>
    </authors>
    <verseOrder>v1 v2 v3</verseOrder>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Cast your burdens unto Jesus (X2)
For he cares for you</lines>
    </verse>
    <verse name="v2">
      <lines>Higher higher higher
Jesus higher</lines>
    </verse>
    <verse name="v3">
      <lines>Lower lower lower
Satan lower</lines>
    </verse>
  </lyrics>
</song>
