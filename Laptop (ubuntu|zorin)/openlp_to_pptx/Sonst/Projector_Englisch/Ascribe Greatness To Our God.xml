<?xml version="1.0" ?>
<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8">
  <properties>
    <titles>
      <title>Ascribe Greatness To Our God</title>
    </titles>
    <authors>
      <author type="words">Mary Kirkbride</author>
      <author type="music">Mary Kirkbride</author>
      <author type="translation">Erzählt von der Größe Gottes</author>
    </authors>
    <verseOrder>v1 v2</verseOrder>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Ascribe greatness to our God, the Rock
His work is perfect,
And all His ways are just</lines>
    </verse>
    <verse name="v2">
      <lines>A God of faithfulness and
without injustice
good and upright is He.</lines>
    </verse>
  </lyrics>
</song>
