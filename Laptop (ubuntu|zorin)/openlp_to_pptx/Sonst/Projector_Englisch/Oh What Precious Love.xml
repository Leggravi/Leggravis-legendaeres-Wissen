<?xml version="1.0" ?>
<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8">
  <properties>
    <titles>
      <title>Oh, What Precious Love</title>
    </titles>
    <authors>
      <author>Unbekannt</author>
    </authors>
    <verseOrder>v1</verseOrder>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Oh, what precious love the Father
Had for Adam's fallen race,
Gave His only Son to suffer,
And redeem us by His Grace.</lines>
    </verse>
  </lyrics>
</song>
