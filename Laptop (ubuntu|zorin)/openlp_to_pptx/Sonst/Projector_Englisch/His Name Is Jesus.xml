<?xml version="1.0" ?>
<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8">
  <properties>
    <titles>
      <title>His Name Is Jesus</title>
    </titles>
    <authors>
      <author type="words">Audrey Mieir</author>
      <author type="music">Audrey Mieir</author>
      <author type="translation">Sein Nam heißt Wunderbar</author>
    </authors>
    <verseOrder>v1</verseOrder>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>His name is Jesus, wonderful Jesus.
His name is Jesus and I love Him so.
Bow down before Him, love and adore Him
His name is Jesus and I love Him so.</lines>
    </verse>
  </lyrics>
</song>
