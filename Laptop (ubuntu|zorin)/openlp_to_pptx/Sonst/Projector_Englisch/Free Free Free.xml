<?xml version="1.0" ?>
<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8">
  <properties>
    <titles>
      <title>Free, Free, Free</title>
    </titles>
    <authors>
      <author>Unbekannt</author>
    </authors>
    <verseOrder>v1</verseOrder>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Free, free, free;
Christ has made me free.
Once I was blind, now I can see,
For I am free, free, free.</lines>
    </verse>
  </lyrics>
