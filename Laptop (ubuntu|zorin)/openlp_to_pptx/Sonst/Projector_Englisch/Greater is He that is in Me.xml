<?xml version="1.0" ?>
<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8">
  <properties>
    <titles>
      <title>Greater is He that is in Me</title>
    </titles>
    <authors>
      <author type="words">Graham Kendrick</author>
      <author type="music">Graham Kendrick</author>
      <author type="translation">Er, der in uns lebt</author>
    </authors>
    <verseOrder>v1</verseOrder>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Greater is He that is in me,
Greater is He that is in me
than he that is the world;</lines>
    </verse>
  </lyrics>
</song>
