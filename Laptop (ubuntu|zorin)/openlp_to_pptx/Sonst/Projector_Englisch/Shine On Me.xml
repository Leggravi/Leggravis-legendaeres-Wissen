  <lyrics>
    <verse name="v1">
      <lines>Shine on me, Lord, shine on me,
Let the light from the Lighthouse
  shine on me;
Shine on me, Lord, shine on me,
Let the light from the Lighthouse
  shine on me.</lines>
    </verse>
  </lyrics>
