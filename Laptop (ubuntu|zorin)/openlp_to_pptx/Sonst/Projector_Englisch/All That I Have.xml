<?xml version="1.0" ?>
<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8">
  <properties>
    <titles>
      <title>All That I Have</title>
    </titles>
    <authors>
      <author>Unbekannt</author>
    </authors>
    <verseOrder>v1</verseOrder>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>All that I have, all that I am,
All I shall ever be,
Cannot repay the love
  debt I owe,
I surrender to Thee.</lines>
    </verse>
  </lyrics>
</song>
