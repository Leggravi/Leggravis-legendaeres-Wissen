<?xml version="1.0" ?>
<song xmlns="http://openlyrics.info/namespace/2009/song" version="0.8">
  <properties>
    <titles>
      <title>Bind Us Together</title>
    </titles>
    <authors>
      <author type="words">Bob Gillman</author>
      <author type="music">Bob Gillman</author>
      <author type="translation">Bind uns zusammen, Herr</author>
    </authors>
    <verseOrder>v1</verseOrder>
  </properties>
  <lyrics>
    <verse name="v1">
      <lines>Bind us together, Lord, bind us together
With cords that cannot be broken
Bind us together, Lord, bind us together
Bind us together with love</lines>
    </verse>
  </lyrics>
</song>
